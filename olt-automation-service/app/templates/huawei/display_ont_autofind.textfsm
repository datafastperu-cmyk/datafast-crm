Value Slot (\d+)
Value Port (\d+)
Value OnuSn ([A-Z]{4}-?[0-9A-F]{8})
Value OntModel (.+?)

Start
  # Formato bloque MA5800: F/S/P : frame/slot/port
  ^.*F/S/P\s+:\s+\d+/${Slot}/${Port}
  # SN viene como "4857544378CA0FAA (HWTC-78CA0FAA)" — capturar el parentético
  ^.*Ont\s+SN\s*:\s+\S+\s+\(${OnuSn}\)
  ^.*Ont\s+EquipmentID\s*:\s+${OntModel}
  ^.*Ont\s+autofind\s+time\s*: -> Record
