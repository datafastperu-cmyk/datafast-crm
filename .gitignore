# ==============================================================
# CRM ISP DATAFAST — .gitignore
# ==============================================================

# ── Entorno ───────────────────────────────────────────────────
.vps.env
.env
.env.local
.env.production
.env.staging
*.env

# ── Temporales de desarrollo / auditoria ──────────────────────
__pycache__/
*.pyc
.playwright-mcp/
*.BACKUP
build-log-*.txt
audit_*.png
verify_*.png
debug_*.png
red_redes_*.png
redes_*.png
verificacion_*.png

# ── SSL y certificados ────────────────────────────────────────
nginx/ssl/live/
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.pem
*.pfx
*.p12
certs/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── NestJS / TypeScript ───────────────────────────────────────
backend/dist/
backend/build/
*.js.map
*.d.ts

# ── Next.js ───────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
log/
# Excepción: rutas Next.js que se llaman "log"
!frontend/src/**/log/
!frontend/src/**/log/**

# ── Uploads (no versionar archivos subidos por usuarios) ──────
backend/uploads/
uploads/

# ── Backups ───────────────────────────────────────────────────
backups/
*.sql
*.sql.gz
*.dump

# ── IDEs ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Docker volumes locales ────────────────────────────────────
.docker/

# ── Herramientas privadas de licencias (NUNCA versionar) ──────
tools/private.pem
tools/generate-license.js

# ── Credenciales locales (NUNCA versionar ni subir a VPS) ─────
ACCESOS.local.md
