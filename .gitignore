# ==============================================================
# FibraNet ISP — .gitignore
# ==============================================================

# ── Entorno ───────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ── SSL y certificados ────────────────────────────────────────
nginx/ssl/live/
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.pem
*.pfx
*.p12
certs/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── NestJS / TypeScript ───────────────────────────────────────
backend/dist/
backend/build/
*.js.map
*.d.ts

# ── Next.js ───────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
log/

# ── Uploads (no versionar archivos subidos por usuarios) ──────
backend/uploads/
uploads/

# ── Backups ───────────────────────────────────────────────────
backups/
*.sql
*.sql.gz
*.dump

# ── IDEs ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Docker volumes locales ────────────────────────────────────
.docker/
