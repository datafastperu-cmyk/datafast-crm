# ==============================================================
# FibraNet ISP ERP — Variables de Entorno
# ==============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Completar TODOS los valores marcados con <CAMBIAR>
# 3. Nunca commitear el .env real al repositorio
# 4. Usar: openssl rand -hex 32  para generar secrets seguros
# ==============================================================

# ── APLICACIÓN ────────────────────────────────────────────────
APP_NAME="FibraNet ISP"
COMPANY_NAME="Mi Empresa ISP S.A.C."
APP_URL=https://app.tudominio.com             # <CAMBIAR>
FRONTEND_URL=https://app.tudominio.com        # <CAMBIAR>
WS_URL=wss://app.tudominio.com                # <CAMBIAR>
ALLOWED_ORIGINS=https://app.tudominio.com,https://portal.tudominio.com   # <CAMBIAR>
NODE_ENV=production
TZ=America/Lima

# ── BASE DE DATOS PostgreSQL ──────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fibranet
DB_USER=fibranet
DB_PASSWORD=<CAMBIAR_PASSWORD_SEGURO_MIN32CHARS>
DB_SSL=false
# Usar esto en producción con RDS/Cloud SQL:
# DB_SSL=true
# DB_SSL_CA=/path/to/ca.pem

# ── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CAMBIAR_PASSWORD_REDIS>

# ── JWT / AUTENTICACIÓN ───────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=<CAMBIAR_SECRET_MUY_LARGO_Y_SEGURO>
JWT_REFRESH_SECRET=<CAMBIAR_REFRESH_SECRET_DIFERENTE>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── ENCRIPTACIÓN (para passwords de routers en BD) ───────────
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=<CAMBIAR_32_BYTES_HEX>

# ── UPLOADS ───────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# ──────────────────────────────────────────────────────────────
# INTEGRACIONES EXTERNAS
# ──────────────────────────────────────────────────────────────

# ── RENIEC Perú ───────────────────────────────────────────────
# Proveedores: apiperu.dev | consulta.pe | reniec.gob.pe
RENIEC_API_URL=https://api.apis.net.pe/v1
RENIEC_API_TOKEN=<CAMBIAR_TOKEN_RENIEC_API>

# ── GOOGLE MAPS ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=<CAMBIAR_GOOGLE_MAPS_API_KEY>

# ── SMARTOLT ──────────────────────────────────────────────────
SMARTOLT_URL=https://smartolt.tuempresa.com   # <CAMBIAR>
SMARTOLT_TOKEN=<CAMBIAR_TOKEN_SMARTOLT>

# ── MERCADOPAGO ───────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.pe/developers
MP_ACCESS_TOKEN=<CAMBIAR_MP_ACCESS_TOKEN>
MP_PUBLIC_KEY=<CAMBIAR_MP_PUBLIC_KEY>
MP_WEBHOOK_SECRET=<CAMBIAR_MP_WEBHOOK_SECRET>

# ── WHATSAPP BUSINESS API (Meta Cloud API) ────────────────────
# Configurar en: https://developers.facebook.com
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=<CAMBIAR_PHONE_NUMBER_ID>
WHATSAPP_TOKEN=<CAMBIAR_WHATSAPP_ACCESS_TOKEN>
WHATSAPP_VERIFY_TOKEN=<CAMBIAR_VERIFY_TOKEN_PROPIO>
WHATSAPP_BUSINESS_ACCOUNT_ID=<CAMBIAR_WABA_ID>

# ── EMAIL SMTP ────────────────────────────────────────────────
# Gmail: smtp.gmail.com:587 (requiere App Password)
# Sendgrid: smtp.sendgrid.net:587
# Hostinger/cPanel: mail.tudominio.com:465
SMTP_HOST=smtp.gmail.com                      # <CAMBIAR>
SMTP_PORT=587
SMTP_SECURE=false                             # true para puerto 465
SMTP_USER=notificaciones@tudominio.com        # <CAMBIAR>
SMTP_PASS=<CAMBIAR_APP_PASSWORD>
SMTP_FROM_NAME="FibraNet ISP"
SMTP_FROM_EMAIL=notificaciones@tudominio.com  # <CAMBIAR>

# ── TWILIO SMS ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<CAMBIAR_TWILIO_SID>
TWILIO_AUTH_TOKEN=<CAMBIAR_TWILIO_TOKEN>
TWILIO_PHONE_NUMBER=+51900000000              # <CAMBIAR>

# ── TELEGRAM BOT ──────────────────────────────────────────────
# Crear bot en: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=<CAMBIAR_TELEGRAM_BOT_TOKEN>
TELEGRAM_ADMIN_CHAT_ID=<CAMBIAR_CHAT_ID_ALERTAS>

# ── SUNAT (Facturación Electrónica) ──────────────────────────
# Ambiente: beta | produccion
SUNAT_AMBIENTE=beta
SUNAT_RUC=<CAMBIAR_RUC_EMPRESA>
SUNAT_USUARIO_SOL=<CAMBIAR_USUARIO_SOL>
SUNAT_CLAVE_SOL=<CAMBIAR_CLAVE_SOL>
SUNAT_CERT_PATH=/app/certs/sunat.pfx
SUNAT_CERT_PASSWORD=<CAMBIAR_PASSWORD_CERTIFICADO>

# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE NEGOCIO
# ──────────────────────────────────────────────────────────────

# ── FACTURACIÓN ───────────────────────────────────────────────
# Día del mes para generar facturas (1-28)
BILLING_DAY=1
# Días de gracia antes del corte automático
GRACE_DAYS=5
# IGV Perú
IGV_RATE=0.18
# Moneda
CURRENCY=PEN
CURRENCY_SYMBOL=S/

# ── MONITOREO ─────────────────────────────────────────────────
# Intervalo de ping a nodos (segundos)
MONITORING_PING_INTERVAL=30
# Intervalo SNMP polling (segundos)
MONITORING_SNMP_INTERVAL=60
# Umbral de latencia para alerta (ms)
ALERT_LATENCY_THRESHOLD_MS=100
# Umbral de pérdida de paquetes para alerta (%)
ALERT_PACKET_LOSS_THRESHOLD=10

# ── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=info    # debug | info | warn | error
LOG_DIR=/app/logs

# ──────────────────────────────────────────────────────────────
# SOLO DESARROLLO
# ──────────────────────────────────────────────────────────────
PGADMIN_PASSWORD=admin123
