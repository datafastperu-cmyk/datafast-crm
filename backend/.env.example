# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=datafast_db
DB_USERNAME=datafast_user
DB_PASSWORD=CHANGE_ME
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_REFRESH
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cifrado (openssl rand -hex 32) ───────────────────────────
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_OPENSSL_RAND_HEX_32

# ─── App ──────────────────────────────────────────────────────
# IMPORTANTE: este ERP se instala en múltiples VPS. Ningún código del repositorio
# debe contener IPs ni URLs hardcodeadas. Toda URL que varíe por servidor va aquí.
NODE_ENV=production
PORT=4000
# URL base del backend (incluye protocolo y puerto). Usada para construir URLs
# de descarga en scripts MikroTik y cualquier referencia interna al propio servidor.
# Ejemplo: http://149.34.48.224:4000  o  https://api.mierp.com
APP_URL=http://IP_PUBLICA_VPS:4000
FRONTEND_URL=http://IP_PUBLICA_VPS:3000
ALLOWED_ORIGINS=http://IP_PUBLICA_VPS:3000

# ─── VPN OpenVPN ──────────────────────────────────────────────
# IP pública del servidor donde corre OpenVPN (sin protocolo ni puerto).
# Los scripts MikroTik generados por el wizard usan este valor en "connect-to".
# Si se omite, se extrae automáticamente de APP_URL.
VPN_SERVER_IP=IP_PUBLICA_VPS
VPN_SERVER_PORT=1195
# Máscara de subred para ifconfig-push en archivos CCD (topología subnet).
# Cambiar a 255.255.255.252 si el servidor usa topología net30.
VPN_CCD_NETMASK=255.255.255.0
# Subred del túnel VPN usada como src-address en la regla firewall API del MikroTik.
# Cambiar si el servidor OpenVPN usa un pool distinto (ej: 10.9.0.0/24).
VPN_SUBNET=10.8.0.0/24

# ─── Licencia ─────────────────────────────────────────────────
# Pegar aquí el JWT de licencia emitido con tools/generate-license.js
LICENSE_KEY=PASTE_YOUR_LICENSE_JWT_HERE

# ─── RENIEC (opcional) ────────────────────────────────────────
RENIEC_API_URL=https://api.reniec.pe/v1
RENIEC_API_KEY=

# ─── Google Workspace Integration ────────────────────────────
# OAuth2: crear proyecto en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI autorizado en Google Cloud Console → Credenciales → URI de redirección
GOOGLE_REDIRECT_URI=https://TU_DOMINIO/v1/google/auth/callback
# Clave para cifrar tokens OAuth en DB (mínimo 32 chars, usar openssl rand -hex 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM
# API Key para Google Maps (sin OAuth, solo geocodificación)
GOOGLE_MAPS_API_KEY=

# ─── SmartOLT (opcional) ──────────────────────────────────────
# Integración con SmartOLT para gestión de ONUs vía API REST.
# Si se omiten, el módulo arranca en modo degradado (visible en GET /api/v1/health/modules).
# El aprovisionamiento nativo SSH a OLTs (NATIVO_SSH) NO se ve afectado.
#
# Pasos para activar:
#   1. Ingresar a SmartOLT → Configuración → API → Generar Token
#   2. Completar los valores abajo en el .env de producción
#   3. Ejecutar: pm2 reload datafast-backend --update-env
#
SMARTOLT_URL=
SMARTOLT_TOKEN=

# ─── Microservicio Python OLT (interno) ───────────────────────
# Servicio local de automatización SSH a OLTs (Huawei, ZTE, V-SOL).
# Por defecto apunta a localhost:8001. Solo cambiar si se mueve a otro host.
OLT_AUTOMATION_SERVICE_URL=http://127.0.0.1:8001
# Debe coincidir con INTERNAL_API_KEY en olt-automation-service/.env
OLT_AUTOMATION_INTERNAL_KEY=tu-clave-secreta-aqui

# ─── Evolution API / WhatsApp (opcional) ──────────────────────
# Instancia local de Evolution API para envío de mensajes WhatsApp.
# Si se omite, el módulo de notificaciones arranca en modo degradado.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# ─── Cobranza / Promesas de pago ────────────────────────────
# Máximo de días que un operador puede otorgar como prórroga (default: 15)
MAX_DIAS_PRORROGA=15
