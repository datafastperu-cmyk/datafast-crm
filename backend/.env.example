# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=datafast_db
DB_USERNAME=datafast_user
DB_PASSWORD=CHANGE_ME
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_REFRESH
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cifrado (openssl rand -hex 32) ───────────────────────────
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_OPENSSL_RAND_HEX_32

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://app.tudominio.com
ALLOWED_ORIGINS=https://app.tudominio.com

# ─── VPN OpenVPN ──────────────────────────────────────────────
# IP pública del servidor VPS/OpenVPN (sin protocolo)
VPN_SERVER_IP=0.0.0.0
VPN_SERVER_PORT=1195

# ─── Licencia ─────────────────────────────────────────────────
# Pegar aquí el JWT de licencia emitido con tools/generate-license.js
LICENSE_KEY=PASTE_YOUR_LICENSE_JWT_HERE

# ─── RENIEC (opcional) ────────────────────────────────────────
RENIEC_API_URL=https://api.reniec.pe/v1
RENIEC_API_KEY=

# ─── Google Workspace Integration ────────────────────────────
# OAuth2: crear proyecto en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI autorizado en Google Cloud Console → Credenciales → URI de redirección
GOOGLE_REDIRECT_URI=https://TU_DOMINIO/v1/google/auth/callback
# Clave para cifrar tokens OAuth en DB (mínimo 32 chars, usar openssl rand -hex 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM
# API Key para Google Maps (sin OAuth, solo geocodificación)
GOOGLE_MAPS_API_KEY=

# ─── SmartOLT (opcional) ──────────────────────────────────────
# Integración con SmartOLT para gestión de ONUs vía API REST.
# Si se omiten, el módulo arranca en modo degradado (visible en GET /api/v1/health/modules).
# El aprovisionamiento nativo SSH a OLTs (NATIVO_SSH) NO se ve afectado.
#
# Pasos para activar:
#   1. Ingresar a SmartOLT → Configuración → API → Generar Token
#   2. Completar los valores abajo en el .env de producción
#   3. Ejecutar: pm2 reload datafast-backend --update-env
#
SMARTOLT_URL=
SMARTOLT_TOKEN=

# ─── Microservicio Python OLT (interno) ───────────────────────
# Servicio local de automatización SSH a OLTs (Huawei, ZTE, V-SOL).
# Por defecto apunta a localhost:8001. Solo cambiar si se mueve a otro host.
OLT_AUTOMATION_SERVICE_URL=http://127.0.0.1:8001
OLT_AUTOMATION_INTERNAL_KEY=

# ─── Evolution API / WhatsApp (opcional) ──────────────────────
# Instancia local de Evolution API para envío de mensajes WhatsApp.
# Si se omite, el módulo de notificaciones arranca en modo degradado.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
