# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=datafast_db
DB_USERNAME=datafast_user
DB_PASSWORD=CHANGE_ME
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Licencia ─────────────────────────────────────────────────
# Pegar aquí el JWT de licencia emitido con tools/generate-license.js
LICENSE_KEY=PASTE_YOUR_LICENSE_JWT_HERE

# ─── RENIEC (opcional) ────────────────────────────────────────
RENIEC_API_URL=https://api.reniec.pe/v1
RENIEC_API_KEY=

# ─── Google Workspace Integration ────────────────────────────
# OAuth2: crear proyecto en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI autorizado en Google Cloud Console → Credenciales → URI de redirección
GOOGLE_REDIRECT_URI=https://TU_DOMINIO/v1/google/auth/callback
# Clave para cifrar tokens OAuth en DB (mínimo 32 chars, usar openssl rand -hex 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM
# API Key para Google Maps (sin OAuth, solo geocodificación)
GOOGLE_MAPS_API_KEY=
